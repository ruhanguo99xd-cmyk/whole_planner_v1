<?xml version="1.0"?>
<package format="3">
  <name>bringup</name>
  <version>0.0.1</version>
  <description>Bringup launch files and configuration for shovel_autowalk</description>

  <!-- 必须字段 -->
  <maintainer email="ruhan@example.com">Ruhan</maintainer>
  <license>Apache-2.0</license>

<!-- 构建工具 -->
  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- ============ ROS2 核心依赖 ============ -->
  <exec_depend>ament_cmake</exec_depend>
  <exec_depend>rclcpp</exec_depend>
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <exec_depend>ros2launch</exec_depend>

  <!-- URDF / TF -->
  <exec_depend>robot_state_publisher</exec_depend>
  <exec_depend>xacro</exec_depend>

  <!-- ============ Nav2 ============ -->
  <exec_depend>nav2_bringup</exec_depend>
  <exec_depend>nav2_map_server</exec_depend>
  <exec_depend>nav2_planner</exec_depend>
  <exec_depend>nav2_controller</exec_depend>
  <exec_depend>nav2_bt_navigator</exec_depend>
  <exec_depend>nav2_recoveries</exec_depend>
  <exec_depend>nav2_amcl</exec_depend>
  <exec_depend>nav2_lifecycle_manager</exec_depend>

  <!-- ============ 自定义包 ============ -->
  <exec_depend>map_server</exec_depend>
  <exec_depend>description</exec_depend>
  <exec_depend>path_to_csv</exec_depend>
  <exec_depend>cmd_vel_recorder</exec_depend>
  <exec_depend>rtk_to_odom</exec_depend>
  <exec_depend>cmd_vel_to_plc</exec_depend>
  <!-- <exec_depend>bringup</exec_depend> -->

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
